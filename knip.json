{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/routeTree.gen.ts"],
  "ignoreBinaries": ["open", "tsup", "tsc"],
  "workspaces": {
    "packages/api": {
      "entry": [
        "src/**/*.cli.ts",
        "modules/**/schema.ts",
        "tools/**/*.{ts,js,mjs}",
        "bench/**/*.{ts,mjs}",
        "experiments/**/*.ts",
        "tsup.config.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**", "test/**"]
    },
    "packages/cli": {
      "entry": ["tsup.config.ts"],
      "project": ["src/**"]
    },
    "packages/sdk": {
      "entry": ["examples/**/*.ts", "test/**/*.test.ts"],
      "project": ["src/**", "test/**"],
      "ignoreDependencies": ["postgres"]
    },
    "apps/admin": {
      "entry": ["src/routes/**/*.tsx", "e2e/**/*.ts", "scripts/**/*.mjs"],
      "project": ["src/**"],
      "ignore": ["src/components/ui/**"]
    }
  }
}
