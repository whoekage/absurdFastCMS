# npm workspaces hoist dependencies to the repo root.
node_modules/

# Build artifacts and logs (per-workspace dirs are also ignored by their own .gitignore).
dist/
*.log

# Playwright E2E artifacts (apps/admin).
test-results/
playwright-report/
playwright/.cache/

# Environment files live inside each workspace (packages/api/.env, .env.test) and are gitignored there.
.env
.env.test

# Local Claude Code workspace (workflows, settings) — not tracked.
.claude/

.DS_Store
