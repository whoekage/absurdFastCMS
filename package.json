{
  "name": "absurdfastcms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm test --workspace @absurd/api",
    "bench": "npm run bench --workspace @absurd/api",
    "db:up": "npm run db:up --workspace @absurd/api",
    "db:down": "npm run db:down --workspace @absurd/api",
    "db:migrate": "npm run db:migrate --workspace @absurd/api"
  }
}
