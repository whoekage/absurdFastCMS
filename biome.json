{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": ["**", "!**/node_modules/**", "!**/dist/**", "!**/.tanstack/**", "!**/playwright-report/**"]
  },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 100 },
  "linter": {
    "enabled": true,
    "rules": { "recommended": false }
  },
  "overrides": [
    {
      "includes": ["packages/api/src/store/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/db/**", "**/http/**", "**/auth/**", "**/storage/**", "**/compose/**"],
                    "message": "Layering: store/** is the BOTTOM engine layer and must not import db/http/auth/storage/compose. (Phase 1 worklist.)"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/api/src/db/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/http/**", "**/auth/**", "**/compose/**"],
                    "message": "Layering: db/** may import engine (store) only; must not import http/auth/compose."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/api/src/auth/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/http/**", "**/compose/**"],
                    "message": "Layering: auth/** may import db/store; must not import http/compose."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
