{
  "name": "@conti/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "conti dev",
    "start": "conti start",
    "test": "node --env-file=.env.test --test --test-global-setup=./test/global-setup.ts",
    "bench": "node bench/scan.bench.ts",
    "typecheck": "tsc -p tsconfig.json",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file=.env src/db/migration.runner.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@better-auth/api-key": "1.6.20",
    "better-auth": "1.6.20",
    "busboy": "^1.6.0",
    "image-size": "^2.0.2",
    "kysely": "^0.29.2",
    "kysely-postgres-js": "3.0.0",
    "postgres": "^3.4.9",
    "set-cookie-parser": "3.1.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.52.0"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@testcontainers/minio": "^12.0.2",
    "@testcontainers/postgresql": "^12.0.2",
    "@types/busboy": "^1.5.4",
    "@types/set-cookie-parser": "2.4.10",
    "autocannon": "^8.0.0",
    "testcontainers": "^12.0.2"
  }
}
